# ============================================================
# 黑卡闪问题智能分析系统 — 环境配置
# 复制此文件为 .env 并填入你的真实配置
# ============================================================

# ── DeepSeek API（必需）──
DEEPSEEK_ANTHROPIC_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_ANTHROPIC_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TIMEOUT_SECONDS=600

# ── 项目路径（可选，默认自动检测）──
# PROJECT_ROOT=D:/my_crew
# KB_PATH=D:/my_crew/black_screen_data/analyzed_bugs.json
# EXCEL_PATH=D:/my_crew/black_screen_data/Bug_20260518.xlsx

# ── Obsidian 保险库（可选）──
# OBSIDIAN_VAULT_PATH=D:/MyVault

# ── NAS 日志存储（可选，用于工作流二）──
# NAS_MOUNT_PATH=//hzhhnnas01.desaysv.com/DIDA6003
